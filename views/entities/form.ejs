<%- include('../partials/header') %>

<div class="row justify-content-center">
  <div class="col-lg-8">
    <div class="card">
      <div class="card-body">
        <h1 class="h4 mb-3"><%= entity ? 'Редактировать запись' : 'Новая запись' %></h1>
        <form method="post" action="<%= entity ? '/entities/' + entity.id : '/entities' %>">
          <div class="mb-3">
            <label class="form-label">Название *</label>
            <input class="form-control" name="title" value="<%= entity?.title || '' %>" required>
          </div>
          <div class="mb-3">
            <label class="form-label">Описание *</label>
            <textarea class="form-control" name="description" rows="4" required><%= entity?.description || '' %></textarea>
          </div>
          <div class="row g-2 mb-3">
            <div class="col-md-6">
              <label class="form-label">Дата начала *</label>
              <input type="date" class="form-control" name="startDate" value="<%= entity?.startDate || '' %>" required>
            </div>
            <div class="col-md-6">
              <label class="form-label">Дата окончания *</label>
              <input type="date" class="form-control" name="endDate" value="<%= entity?.endDate || '' %>" required>
            </div>
          </div>
          <div class="row g-2 mb-3">
            <div class="col-md-4">
              <label class="form-label">Бюджет</label>
              <input type="number" step="0.01" class="form-control" name="priceOrBudget" value="<%= entity?.priceOrBudget || '' %>">
            </div>
            <div class="col-md-4">
              <label class="form-label">Статус *</label>
              <select class="form-select" name="statusId" required>
                <% statuses.forEach((s) => { %>
                  <option value="<%= s.id %>" <%= entity && String(entity.StatusId) === String(s.id) ? 'selected' : '' %>><%= s.name %></option>
                <% }) %>
              </select>
            </div>
            <div class="col-md-4">
              <label class="form-label">Тип *</label>
              <select class="form-select" name="typeId" required>
                <% types.forEach((t) => { %>
                  <option value="<%= t.id %>" <%= entity && String(entity.TypeId) === String(t.id) ? 'selected' : '' %>><%= t.name %></option>
                <% }) %>
              </select>
            </div>
          </div>
          <div class="mb-3">
            <label class="form-label">Исполнитель</label>
            <select class="form-select" name="assigneeId">
              <option value="">Не назначен</option>
              <% users.forEach((u) => { %>
                <option value="<%= u.id %>" <%= entity && String(entity.assigneeId) === String(u.id) ? 'selected' : '' %>><%= u.fullName %></option>
              <% }) %>
            </select>
          </div>
          <div class="d-flex gap-2">
            <button class="btn btn-primary" type="submit">Сохранить</button>
            <a class="btn btn-outline-secondary" href="/entities">Назад</a>
          </div>
        </form>
      </div>
    </div>
  </div>
</div>

<%- include('../partials/footer') %>
