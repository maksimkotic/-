<%- include('../partials/header') %>

<div class="d-flex justify-content-between align-items-center mb-3">
  <h1 class="h3 m-0">Список сущностей</h1>
  <% if (user && (user.role === 'admin' || user.role === 'manager')) { %>
    <a class="btn btn-primary" href="/entities/new">Добавить</a>
  <% } %>
</div>

<div class="card mb-4">
  <div class="card-body">
    <form method="get" action="/entities" class="row g-2">
      <div class="col-md-2">
        <select name="statusId" class="form-select">
          <option value="">Статус</option>
          <% statuses.forEach((s) => { %>
            <option value="<%= s.id %>" <%= String(filters.statusId) === String(s.id) ? 'selected' : '' %>><%= s.name %></option>
          <% }) %>
        </select>
      </div>
      <div class="col-md-2">
        <select name="typeId" class="form-select">
          <option value="">Тип</option>
          <% types.forEach((t) => { %>
            <option value="<%= t.id %>" <%= String(filters.typeId) === String(t.id) ? 'selected' : '' %>><%= t.name %></option>
          <% }) %>
        </select>
      </div>
      <div class="col-md-2">
        <select name="assigneeId" class="form-select">
          <option value="">Исполнитель</option>
          <% users.forEach((u) => { %>
            <option value="<%= u.id %>" <%= String(filters.assigneeId) === String(u.id) ? 'selected' : '' %>><%= u.fullName %></option>
          <% }) %>
        </select>
      </div>
      <div class="col-md-2"><input type="date" name="dateFrom" value="<%= filters.dateFrom || '' %>" class="form-control"></div>
      <div class="col-md-2"><input type="date" name="dateTo" value="<%= filters.dateTo || '' %>" class="form-control"></div>
      <div class="col-md-2 d-grid"><button class="btn btn-outline-primary">Фильтр</button></div>
    </form>
  </div>
</div>

<div class="table-responsive">
  <table class="table table-striped table-hover align-middle">
    <thead>
      <tr>
        <th>#</th>
        <th>Название</th>
        <th>Описание</th>
        <th>Даты</th>
        <th>Статус</th>
        <th>Тип</th>
        <th>Исполнитель</th>
        <th>Бюджет</th>
        <th>Действия</th>
      </tr>
    </thead>
    <tbody>
      <% entities.forEach((entity) => { %>
        <tr>
          <td><%= entity.id %></td>
          <td><%= entity.title %></td>
          <td><%= entity.description %></td>
          <td><%= entity.startDate %> — <%= entity.endDate %></td>
          <td><span class="badge text-bg-secondary"><%= entity.Status?.name %></span></td>
          <td><%= entity.Type?.name %></td>
          <td><%= entity.assignee?.fullName || '-' %></td>
          <td><%= entity.priceOrBudget || '-' %></td>
          <td>
            <% if (user && (user.role === 'admin' || user.role === 'manager')) { %>
              <a href="/entities/<%= entity.id %>/edit" class="btn btn-sm btn-warning">Изм.</a>
              <form action="/entities/<%= entity.id %>/delete" method="post" class="d-inline">
                <button type="submit" class="btn btn-sm btn-danger">Удал.</button>
              </form>
            <% } else { %>
              -
            <% } %>
          </td>
        </tr>
      <% }) %>
      <% if (!entities.length) { %>
        <tr>
          <td colspan="9" class="text-center text-muted py-4">Нет данных по выбранным фильтрам.</td>
        </tr>
      <% } %>
    </tbody>
  </table>
</div>

<%- include('../partials/footer') %>
